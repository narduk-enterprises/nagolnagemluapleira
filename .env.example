# App (or use Doppler project nuxt_template — see scripts/doppler-env-keys.txt)
APP_URL=http://localhost:3000

# Apple Sign-In (from Apple Developer portal)
APPLE_TEAM_ID=
APPLE_CLIENT_ID=
APPLE_KEY_ID=
APPLE_SECRET_KEY=

# PostHog Analytics
POSTHOG_PUBLIC_KEY=
# For automation (setup:posthog): PostHog → Settings → Personal API Keys, scope project:write
POSTHOG_PERSONAL_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Google Analytics 4
GA_MEASUREMENT_ID=
# For automation (setup:ga): analytics.google.com → Admin → Account ID (numeric)
GA_ACCOUNT_ID=

# Google Search Console Automation
# Option A: path to the downloaded JSON key file (local)
GSC_SERVICE_ACCOUNT_JSON_PATH=
# Option B: raw JSON or base64 (use in Doppler: node scripts/doppler-b64-key.mjs ./key.json)
GSC_SERVICE_ACCOUNT_JSON=
GSC_USER_EMAIL=
SITE_URL=http://localhost:3000

# Apple MapKit JS
NUXT_PUBLIC_MAPKIT_TOKEN=
